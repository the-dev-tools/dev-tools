{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",

  "name": "server",
  "projectType": "application",

  "implicitDependencies": ["db"],

  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go build -o dist/server cmd/server/server.go"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go run cmd/server/server.go"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go test -p 8 ./... -timeout 30s"
      }
    },
    "test:ci": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "parallel": false,
        "commands": [
          "rm --force dist/tests.json",
          "mkdir --parents dist",
          "go test ./... -json -timeout 60s | tee dist/go-test.json"
        ]
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "parallel": false,
        "command": "go test -timeout 60s ./internal/api/middleware/... ./pkg/assertv2 ./pkg/depfinder ./pkg/errmap ./pkg/expression ./pkg/flow/node/nrequest ./pkg/http/... ./pkg/httpclient ./pkg/idwrap ./pkg/io/yamlflow/yamlflowsimple ./pkg/ioworkspace ./pkg/migrate ./pkg/service/sitemapiexample ./pkg/service/snodeexecution ./pkg/service/svar ./pkg/translate/tcurl ./pkg/translate/thar ./pkg/varsystem ./pkg/zstdcompress"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "golangci-lint run"
      }
    },
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go mod tidy"
      }
    }
  }
}
